# swagapp local-dev environment.
# Copy this file to .env and either replace the right-hand sides with
# literal values or with `op://...` references resolved by `op run`.
#
# `op://...` values live in the 1Password item
#   Mensa Auth Preshared Keys (Private vault).
# Local backend is started with:
#   op run --env-file .env -- docker-compose up backend mongo

# --- Mensa Auth / backend secrets ---
LOGINM_SEED="op://Personal/Mensa Auth Preshared Keys/preshared-1"
LOGINB_SEED="op://Personal/Mensa Auth Preshared Keys/preshared-2"
EVENT_API_TOKEN="op://Personal/Mensa Auth Preshared Keys/backendtoken"
GOOGLE_MAPS_API_KEY="op://Personal/Mensa Auth Preshared Keys/GOOGLE_MAPS_API_KEY"

# Anything sufficiently random. Used by the backend to sign JWTs and to
# salt the feedback user hash.
SECRET_KEY=yourVerySecretKeyHere

# Your Mensa member number — auto-logs you in as yourself in TEST_MODE.
MY_USER_ID=2007529

# Host port the backend container is mapped to.
BACKEND_PORT=8043

# --- GitHub App used by the feedback feature ---
# Production secrets live in the same 1Password item; the PEM is an
# attachment whose filename is the op:// field name.
GITHUB_APP_ID="op://Personal/Mensa Auth Preshared Keys/github-app-id"
GITHUB_CLIENT_ID="op://Personal/Mensa Auth Preshared Keys/github-client-id"
GITHUB_CLIENT_SECRET="op://Personal/Mensa Auth Preshared Keys/github-client-secret"
GITHUB_APP_PRIVATE_KEY="op://Personal/Mensa Auth Preshared Keys/swag-app-github-issues-link.2026-05-12.private-key.pem"
